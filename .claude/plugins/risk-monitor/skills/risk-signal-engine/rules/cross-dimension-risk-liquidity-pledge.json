{
  "rule_id": "CROSS_002",
  "version": "0.1.0",
  "status": "active",
  "rule_type": "cross_dimension",
  "risk_dimensions": [
    "equity-pledge-risk-monitor",
    "liquidity-impact-estimator",
    "limit-up-limit-down-risk-checker"
  ],
  "scope": {
    "market": "CN-A",
    "universe": "all_watchlist",
    "position_stage": "post_position"
  },
  "inputs_required": [
    {
      "name": "pledge_ratio_controlling_shareholder",
      "type": "number",
      "source": "filing_update",
      "required": true
    },
    {
      "name": "estimated_slippage_1pct_notional",
      "type": "number",
      "source": "market",
      "required": true
    },
    {
      "name": "consecutive_limit_down_days",
      "type": "number",
      "source": "market",
      "required": true
    }
  ],
  "logic": {
    "expression": "pledge_ratio_controlling_shareholder > 0.4 && estimated_slippage_1pct_notional > 0.015 && consecutive_limit_down_days >= 1",
    "thresholds": {
      "pledge_ratio_controlling_shareholder": 0.4,
      "estimated_slippage_1pct_notional": 0.015,
      "consecutive_limit_down_days": 1
    },
    "lookback_window": "20d",
    "trigger_mode": "hybrid",
    "explain_template": "高质押+低流动性+跌停共振，尾部风险显著抬升。"
  },
  "severity": {
    "mapping": [
      {
        "condition": "consecutive_limit_down_days >= 2",
        "level": "critical"
      }
    ],
    "default_level": "high"
  },
  "confidence": {
    "method": "heuristic",
    "base_score": 0.83
  },
  "event_triggers": [
    {
      "source": "market_anomaly",
      "event_type": "limit_down",
      "action": "escalate"
    },
    {
      "source": "filing_update",
      "event_type": "equity_pledge_update",
      "action": "recompute"
    }
  ],
  "invalidation_conditions": [
    "pledge_ratio_controlling_shareholder < 0.25",
    "estimated_slippage_1pct_notional < 0.01"
  ],
  "output_contract": {
    "must_include_fields": [
      "alert_id",
      "security_id",
      "as_of_date",
      "risk_type",
      "severity",
      "thesis",
      "evidence_refs",
      "trigger_logic",
      "confidence",
      "expected_window",
      "invalidation_conditions",
      "monitor_next"
    ]
  },
  "ownership": {
    "owner": "risk-team",
    "reviewer": "trading-risk",
    "created_at": "2026-03-26",
    "last_validated_at": "2026-04-12"
  },
  "legacy_parity_refs": [
    {
      "capability_id": "CAP-001",
      "risk_dimension": "equity-pledge-risk-monitor",
      "legacy_skill_path": ".claude/plugins/risk-monitor/skills/legacy/equity-pledge-risk-monitor",
      "legacy_capability_unit": "控股股东高质押+平仓线预警"
    },
    {
      "capability_id": "CAP-009",
      "risk_dimension": "liquidity-impact-estimator",
      "legacy_skill_path": ".claude/plugins/risk-monitor/skills/legacy/liquidity-impact-estimator",
      "legacy_capability_unit": "交易冲击成本与流动性缺口评估"
    },
    {
      "capability_id": "CAP-008",
      "risk_dimension": "limit-up-limit-down-risk-checker",
      "legacy_skill_path": ".claude/plugins/risk-monitor/skills/legacy/limit-up-limit-down-risk-checker",
      "legacy_capability_unit": "涨跌停板流动性锁死风险检查"
    }
  ]
}
