{
  "rule_id": "LOCKUP_002",
  "version": "0.1.0",
  "status": "active",
  "rule_type": "single_dimension",
  "risk_dimensions": [
    "ipo-lockup-risk-monitor"
  ],
  "scope": {
    "market": "CN-A",
    "universe": "recent_ipo",
    "position_stage": "post_selection_pre_position"
  },
  "inputs_required": [
    {
      "name": "unlock_ratio_90d",
      "type": "number",
      "source": "filing_update",
      "required": true
    },
    {
      "name": "current_float_mktcap",
      "type": "number",
      "source": "market",
      "required": true
    },
    {
      "name": "avg_turnover_value_20d",
      "type": "number",
      "source": "market",
      "required": true
    }
  ],
  "logic": {
    "expression": "unlock_ratio_90d > 0.25 && unlock_ratio_90d * current_float_mktcap > 15 * avg_turnover_value_20d",
    "thresholds": {
      "unlock_ratio_90d": 0.25,
      "liquidity_cover_days": 15
    },
    "lookback_window": "90d",
    "trigger_mode": "hybrid",
    "explain_template": "\u672a\u676590\u5929\u89e3\u7981\u89c4\u6a21\u76f8\u5bf9\u6210\u4ea4\u627f\u63a5\u80fd\u529b\u8fc7\u5927\uff0c\u4f9b\u7ed9\u51b2\u51fb\u6982\u7387\u9ad8\u3002"
  },
  "severity": {
    "mapping": [
      {
        "condition": "unlock_ratio_90d > 0.4",
        "level": "critical"
      }
    ],
    "default_level": "high"
  },
  "confidence": {
    "method": "heuristic",
    "base_score": 0.79
  },
  "event_triggers": [
    {
      "source": "filing_update",
      "event_type": "lockup_schedule_update",
      "action": "recompute"
    }
  ],
  "invalidation_conditions": [
    "unlock_ratio_90d < 0.1"
  ],
  "output_contract": {
    "must_include_fields": [
      "alert_id",
      "security_id",
      "as_of_date",
      "risk_type",
      "severity",
      "thesis",
      "evidence_refs",
      "trigger_logic",
      "confidence",
      "expected_window",
      "invalidation_conditions",
      "monitor_next"
    ]
  },
  "ownership": {
    "owner": "risk-team",
    "reviewer": "event-risk",
    "created_at": "2026-03-26",
    "last_validated_at": "2026-04-12"
  }
}
