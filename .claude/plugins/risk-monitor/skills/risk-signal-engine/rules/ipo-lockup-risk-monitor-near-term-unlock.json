{
  "rule_id": "LOCKUP_002",
  "version": "0.1.0",
  "status": "active",
  "rule_type": "single_dimension",
  "risk_dimensions": [
    "ipo-lockup-risk-monitor"
  ],
  "scope": {
    "market": "CN-A",
    "universe": "recent_ipo",
    "position_stage": "post_selection_pre_position"
  },
  "inputs_required": [
    {
      "name": "unlock_ratio_90d",
      "type": "number",
      "source": "filing_update",
      "required": true
    },
    {
      "name": "current_float_mktcap",
      "type": "number",
      "source": "market",
      "required": true
    },
    {
      "name": "avg_turnover_value_20d",
      "type": "number",
      "source": "market",
      "required": true
    }
  ],
  "logic": {
    "expression": "unlock_ratio_90d > 0.25 && unlock_ratio_90d * current_float_mktcap > 15 * avg_turnover_value_20d",
    "thresholds": {
      "unlock_ratio_90d": 0.25,
      "liquidity_cover_days": 15
    },
    "lookback_window": "90d",
    "trigger_mode": "hybrid",
    "explain_template": "未来90天解禁规模相对成交承接能力过大，供给冲击概率高。"
  },
  "severity": {
    "mapping": [
      {
        "condition": "unlock_ratio_90d > 0.4",
        "level": "critical"
      }
    ],
    "default_level": "high"
  },
  "confidence": {
    "method": "heuristic",
    "base_score": 0.79
  },
  "event_triggers": [
    {
      "source": "filing_update",
      "event_type": "lockup_schedule_update",
      "action": "recompute"
    }
  ],
  "invalidation_conditions": [
    "unlock_ratio_90d < 0.1"
  ],
  "output_contract": {
    "must_include_fields": [
      "alert_id",
      "security_id",
      "as_of_date",
      "risk_type",
      "severity",
      "thesis",
      "evidence_refs",
      "trigger_logic",
      "confidence",
      "expected_window",
      "invalidation_conditions",
      "monitor_next"
    ]
  },
  "ownership": {
    "owner": "risk-team",
    "reviewer": "event-risk",
    "created_at": "2026-03-26"
  }
}
