{
  "rule_id": "LIMIT_002",
  "version": "0.1.0",
  "status": "active",
  "rule_type": "single_dimension",
  "risk_dimensions": [
    "limit-up-limit-down-risk-checker"
  ],
  "scope": {
    "market": "CN-A",
    "universe": "small_cap",
    "position_stage": "post_position"
  },
  "inputs_required": [
    {
      "name": "limit_up_open_board_count_5d",
      "type": "number",
      "source": "market",
      "required": true
    },
    {
      "name": "upper_shadow_ratio_5d",
      "type": "number",
      "source": "market",
      "required": true
    }
  ],
  "logic": {
    "expression": "limit_up_open_board_count_5d >= 2 && upper_shadow_ratio_5d > 0.06",
    "thresholds": {
      "limit_up_open_board_count_5d": 2,
      "upper_shadow_ratio_5d": 0.06
    },
    "lookback_window": "5d",
    "trigger_mode": "hybrid",
    "explain_template": "\u8fde\u677f\u70b8\u677f\u9891\u7e41\u4e14\u4e0a\u5f71\u7ebf\u653e\u5927\uff0c\u60c5\u7eea\u8d44\u91d1\u63a5\u529b\u8870\u7aed\u3002"
  },
  "severity": {
    "mapping": [
      {
        "condition": "limit_up_open_board_count_5d >= 3",
        "level": "high"
      }
    ],
    "default_level": "medium"
  },
  "confidence": {
    "method": "heuristic",
    "base_score": 0.71
  },
  "event_triggers": [
    {
      "source": "market_anomaly",
      "event_type": "open_board_after_limit_up",
      "action": "recompute"
    }
  ],
  "invalidation_conditions": [
    "limit_up_open_board_count_5d == 0"
  ],
  "output_contract": {
    "must_include_fields": [
      "alert_id",
      "security_id",
      "as_of_date",
      "risk_type",
      "severity",
      "thesis",
      "evidence_refs",
      "trigger_logic",
      "confidence",
      "expected_window",
      "invalidation_conditions",
      "monitor_next"
    ]
  },
  "ownership": {
    "owner": "risk-team",
    "reviewer": "event-risk",
    "created_at": "2026-03-26",
    "last_validated_at": "2026-04-12"
  }
}
