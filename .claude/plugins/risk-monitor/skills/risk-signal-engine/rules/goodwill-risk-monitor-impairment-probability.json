{
  "rule_id": "GOODWILL_002",
  "version": "0.1.0",
  "status": "active",
  "rule_type": "single_dimension",
  "risk_dimensions": [
    "goodwill-risk-monitor"
  ],
  "scope": {
    "market": "CN-A",
    "universe": "all_watchlist",
    "position_stage": "post_selection_pre_position"
  },
  "inputs_required": [
    {
      "name": "goodwill_to_equity",
      "type": "number",
      "source": "lixinger",
      "required": true
    },
    {
      "name": "acquired_subsidiary_revenue_decline_yoy",
      "type": "number",
      "source": "lixinger",
      "required": true
    },
    {
      "name": "cashflow_to_netprofit_ttm",
      "type": "number",
      "source": "lixinger",
      "required": true
    }
  ],
  "logic": {
    "expression": "goodwill_to_equity > 0.35 && acquired_subsidiary_revenue_decline_yoy < -0.15 && cashflow_to_netprofit_ttm < 0.7",
    "thresholds": {
      "goodwill_to_equity": 0.35,
      "acquired_subsidiary_revenue_decline_yoy": -0.15,
      "cashflow_to_netprofit_ttm": 0.7
    },
    "lookback_window": "4q",
    "trigger_mode": "batch",
    "explain_template": "\u5546\u8a89\u5360\u6bd4\u9ad8\u4e14\u5e76\u8d2d\u6807\u7684\u7ecf\u8425\u6076\u5316\uff0c\u51cf\u503c\u98ce\u9669\u4e0a\u5347\u3002"
  },
  "severity": {
    "mapping": [
      {
        "condition": "goodwill_to_equity > 0.5 && acquired_subsidiary_revenue_decline_yoy < -0.25",
        "level": "critical"
      }
    ],
    "default_level": "high"
  },
  "confidence": {
    "method": "heuristic",
    "base_score": 0.8
  },
  "event_triggers": [
    {
      "source": "filing_update",
      "event_type": "quarterly_report",
      "action": "recompute"
    }
  ],
  "invalidation_conditions": [
    "goodwill_to_equity < 0.25",
    "acquired_subsidiary_revenue_decline_yoy > -0.05"
  ],
  "output_contract": {
    "must_include_fields": [
      "alert_id",
      "security_id",
      "as_of_date",
      "risk_type",
      "severity",
      "thesis",
      "evidence_refs",
      "trigger_logic",
      "confidence",
      "expected_window",
      "invalidation_conditions",
      "monitor_next"
    ]
  },
  "ownership": {
    "owner": "risk-team",
    "reviewer": "fundamental-risk",
    "created_at": "2026-03-26",
    "last_validated_at": "2026-04-12"
  }
}
