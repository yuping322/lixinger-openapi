{
  "rule_id": "MARGIN_002",
  "version": "0.1.0",
  "status": "active",
  "rule_type": "single_dimension",
  "risk_dimensions": [
    "margin-risk-monitor"
  ],
  "scope": {
    "market": "CN-A",
    "universe": "all_watchlist",
    "position_stage": "post_position"
  },
  "inputs_required": [
    {
      "name": "margin_balance_to_float_mktcap",
      "type": "number",
      "source": "market",
      "required": true
    },
    {
      "name": "turnover_ratio_5d",
      "type": "number",
      "source": "market",
      "required": true
    },
    {
      "name": "intraday_max_drawdown_5d",
      "type": "number",
      "source": "market",
      "required": true
    }
  ],
  "logic": {
    "expression": "margin_balance_to_float_mktcap > 0.08 && turnover_ratio_5d > 0.18 && intraday_max_drawdown_5d < -0.08",
    "thresholds": {
      "margin_balance_to_float_mktcap": 0.08,
      "turnover_ratio_5d": 0.18,
      "intraday_max_drawdown_5d": -0.08
    },
    "lookback_window": "5d",
    "trigger_mode": "hybrid",
    "explain_template": "\u878d\u8d44\u62e5\u6324\u4ea4\u6613\u5e76\u51fa\u73b0\u9ad8\u6ce2\u52a8\u56de\u64a4\uff0c\u53ef\u80fd\u8fdb\u5165\u8fde\u9501\u53bb\u6760\u6746\u3002"
  },
  "severity": {
    "mapping": [
      {
        "condition": "margin_balance_to_float_mktcap > 0.12",
        "level": "critical"
      }
    ],
    "default_level": "high"
  },
  "confidence": {
    "method": "heuristic",
    "base_score": 0.77
  },
  "event_triggers": [
    {
      "source": "market_anomaly",
      "event_type": "intraday_flash_crash",
      "action": "escalate"
    }
  ],
  "invalidation_conditions": [
    "margin_balance_to_float_mktcap < 0.05",
    "intraday_max_drawdown_5d > -0.03"
  ],
  "output_contract": {
    "must_include_fields": [
      "alert_id",
      "security_id",
      "as_of_date",
      "risk_type",
      "severity",
      "thesis",
      "evidence_refs",
      "trigger_logic",
      "confidence",
      "expected_window",
      "invalidation_conditions",
      "monitor_next"
    ]
  },
  "ownership": {
    "owner": "risk-team",
    "reviewer": "trading-risk",
    "created_at": "2026-03-26",
    "last_validated_at": "2026-04-12"
  }
}
