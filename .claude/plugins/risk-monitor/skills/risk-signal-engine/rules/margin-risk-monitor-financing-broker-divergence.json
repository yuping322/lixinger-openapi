{
  "rule_id": "MARGIN_003",
  "version": "0.1.0",
  "status": "active",
  "rule_type": "cross_dimension",
  "risk_dimensions": [
    "margin-risk-monitor",
    "liquidity-impact-estimator"
  ],
  "scope": {
    "market": "CN-A",
    "universe": "high_beta",
    "position_stage": "post_position"
  },
  "inputs_required": [
    {
      "name": "financing_balance_change_10d",
      "type": "number",
      "source": "market",
      "required": true
    },
    {
      "name": "order_book_depth_drop_10d",
      "type": "number",
      "source": "market",
      "required": true
    }
  ],
  "logic": {
    "expression": "financing_balance_change_10d > 0.15 && order_book_depth_drop_10d < -0.25",
    "thresholds": {
      "financing_balance_change_10d": 0.15,
      "order_book_depth_drop_10d": -0.25
    },
    "lookback_window": "10d",
    "trigger_mode": "hybrid",
    "explain_template": "融资扩张与盘口深度下降并存，边际冲击成本抬升。"
  },
  "severity": {
    "mapping": [
      {
        "condition": "financing_balance_change_10d > 0.25 && order_book_depth_drop_10d < -0.35",
        "level": "critical"
      }
    ],
    "default_level": "high"
  },
  "confidence": {
    "method": "heuristic",
    "base_score": 0.74
  },
  "event_triggers": [
    {
      "source": "market_anomaly",
      "event_type": "depth_collapse",
      "action": "recompute"
    }
  ],
  "invalidation_conditions": [
    "financing_balance_change_10d < 0.05",
    "order_book_depth_drop_10d > -0.1"
  ],
  "output_contract": {
    "must_include_fields": [
      "alert_id",
      "security_id",
      "as_of_date",
      "risk_type",
      "severity",
      "thesis",
      "evidence_refs",
      "trigger_logic",
      "confidence",
      "expected_window",
      "invalidation_conditions",
      "monitor_next"
    ]
  },
  "ownership": {
    "owner": "risk-team",
    "reviewer": "trading-risk",
    "created_at": "2026-03-26",
    "last_validated_at": "2026-04-12"
  },
  "legacy_parity_refs": [
    {
      "capability_id": "CAP-007",
      "risk_dimension": "margin-risk-monitor",
      "legacy_skill_path": ".claude/plugins/risk-monitor/skills/legacy/margin-risk-monitor",
      "legacy_capability_unit": "两融杠杆拥挤与踩踏风险监控"
    },
    {
      "capability_id": "CAP-009",
      "risk_dimension": "liquidity-impact-estimator",
      "legacy_skill_path": ".claude/plugins/risk-monitor/skills/legacy/liquidity-impact-estimator",
      "legacy_capability_unit": "交易冲击成本与流动性缺口评估"
    }
  ]
}
