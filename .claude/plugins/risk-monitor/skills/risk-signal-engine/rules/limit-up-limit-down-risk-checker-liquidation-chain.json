{
  "rule_id": "LIMIT_003",
  "version": "0.1.0",
  "status": "active",
  "rule_type": "cross_dimension",
  "risk_dimensions": [
    "limit-up-limit-down-risk-checker",
    "margin-risk-monitor"
  ],
  "scope": {
    "market": "CN-A",
    "universe": "all_watchlist",
    "position_stage": "post_position"
  },
  "inputs_required": [
    {
      "name": "consecutive_limit_down_days",
      "type": "number",
      "source": "market",
      "required": true
    },
    {
      "name": "margin_balance_change_3d",
      "type": "number",
      "source": "market",
      "required": true
    }
  ],
  "logic": {
    "expression": "consecutive_limit_down_days >= 2 && margin_balance_change_3d < -0.1",
    "thresholds": {
      "consecutive_limit_down_days": 2,
      "margin_balance_change_3d": -0.1
    },
    "lookback_window": "3d",
    "trigger_mode": "event",
    "explain_template": "连续跌停并伴随融资余额骤降，疑似被动平仓链条启动。"
  },
  "severity": {
    "mapping": [
      {
        "condition": "consecutive_limit_down_days >= 3",
        "level": "critical"
      }
    ],
    "default_level": "high"
  },
  "confidence": {
    "method": "heuristic",
    "base_score": 0.81
  },
  "event_triggers": [
    {
      "source": "market_anomaly",
      "event_type": "consecutive_limit_down",
      "action": "escalate"
    }
  ],
  "invalidation_conditions": [
    "consecutive_limit_down_days == 0",
    "margin_balance_change_3d > -0.02"
  ],
  "output_contract": {
    "must_include_fields": [
      "alert_id",
      "security_id",
      "as_of_date",
      "risk_type",
      "severity",
      "thesis",
      "evidence_refs",
      "trigger_logic",
      "confidence",
      "expected_window",
      "invalidation_conditions",
      "monitor_next"
    ]
  },
  "ownership": {
    "owner": "risk-team",
    "reviewer": "trading-risk",
    "created_at": "2026-03-26",
    "last_validated_at": "2026-04-12"
  },
  "legacy_parity_refs": [
    {
      "capability_id": "CAP-008",
      "risk_dimension": "limit-up-limit-down-risk-checker",
      "legacy_skill_path": ".claude/plugins/risk-monitor/skills/legacy/limit-up-limit-down-risk-checker",
      "legacy_capability_unit": "涨跌停板流动性锁死风险检查"
    },
    {
      "capability_id": "CAP-007",
      "risk_dimension": "margin-risk-monitor",
      "legacy_skill_path": ".claude/plugins/risk-monitor/skills/legacy/margin-risk-monitor",
      "legacy_capability_unit": "两融杠杆拥挤与踩踏风险监控"
    }
  ]
}
