{
  "rule_id": "LIMIT_003",
  "version": "0.1.0",
  "status": "active",
  "rule_type": "cross_dimension",
  "risk_dimensions": [
    "limit-up-limit-down-risk-checker",
    "margin-risk-monitor"
  ],
  "scope": {
    "market": "CN-A",
    "universe": "all_watchlist",
    "position_stage": "post_position"
  },
  "inputs_required": [
    {
      "name": "consecutive_limit_down_days",
      "type": "number",
      "source": "market",
      "required": true
    },
    {
      "name": "margin_balance_change_3d",
      "type": "number",
      "source": "market",
      "required": true
    }
  ],
  "logic": {
    "expression": "consecutive_limit_down_days >= 2 && margin_balance_change_3d < -0.1",
    "thresholds": {
      "consecutive_limit_down_days": 2,
      "margin_balance_change_3d": -0.1
    },
    "lookback_window": "3d",
    "trigger_mode": "event",
    "explain_template": "\u8fde\u7eed\u8dcc\u505c\u5e76\u4f34\u968f\u878d\u8d44\u4f59\u989d\u9aa4\u964d\uff0c\u7591\u4f3c\u88ab\u52a8\u5e73\u4ed3\u94fe\u6761\u542f\u52a8\u3002"
  },
  "severity": {
    "mapping": [
      {
        "condition": "consecutive_limit_down_days >= 3",
        "level": "critical"
      }
    ],
    "default_level": "high"
  },
  "confidence": {
    "method": "heuristic",
    "base_score": 0.81
  },
  "event_triggers": [
    {
      "source": "market_anomaly",
      "event_type": "consecutive_limit_down",
      "action": "escalate"
    }
  ],
  "invalidation_conditions": [
    "consecutive_limit_down_days == 0",
    "margin_balance_change_3d > -0.02"
  ],
  "output_contract": {
    "must_include_fields": [
      "alert_id",
      "security_id",
      "as_of_date",
      "risk_type",
      "severity",
      "thesis",
      "evidence_refs",
      "trigger_logic",
      "confidence",
      "expected_window",
      "invalidation_conditions",
      "monitor_next"
    ]
  },
  "ownership": {
    "owner": "risk-team",
    "reviewer": "trading-risk",
    "created_at": "2026-03-26",
    "last_validated_at": "2026-04-12"
  }
}
