{
  "rule_id": "ST_003",
  "version": "0.1.0",
  "status": "active",
  "rule_type": "event_only",
  "risk_dimensions": [
    "st-delist-risk-scanner"
  ],
  "scope": {
    "market": "CN-A",
    "universe": "all_watchlist",
    "position_stage": "post_position"
  },
  "inputs_required": [
    {
      "name": "exchange_inquiry_unresolved_days",
      "type": "number",
      "source": "announcement",
      "required": true
    },
    {
      "name": "major_violation_case",
      "type": "boolean",
      "source": "news",
      "required": true
    }
  ],
  "logic": {
    "expression": "exchange_inquiry_unresolved_days > 30 || major_violation_case == true",
    "thresholds": {
      "exchange_inquiry_unresolved_days": 30
    },
    "lookback_window": "90d",
    "trigger_mode": "event",
    "explain_template": "\u76d1\u7ba1\u95ee\u8be2\u957f\u671f\u672a\u56de\u590d\u6216\u91cd\u5927\u8fdd\u89c4\u7acb\u6848\uff0c\u9000\u5e02\u4e0e\u4ea4\u6613\u9650\u5236\u98ce\u9669\u5347\u6e29\u3002"
  },
  "severity": {
    "mapping": [
      {
        "condition": "major_violation_case == true && exchange_inquiry_unresolved_days > 60",
        "level": "critical"
      }
    ],
    "default_level": "high"
  },
  "confidence": {
    "method": "heuristic",
    "base_score": 0.8
  },
  "event_triggers": [
    {
      "source": "announcement",
      "event_type": "exchange_inquiry",
      "action": "open_watch"
    },
    {
      "source": "news",
      "event_type": "regulatory_case_filing",
      "action": "escalate"
    }
  ],
  "invalidation_conditions": [
    "exchange_inquiry_unresolved_days < 10",
    "major_violation_case == false"
  ],
  "output_contract": {
    "must_include_fields": [
      "alert_id",
      "security_id",
      "as_of_date",
      "risk_type",
      "severity",
      "thesis",
      "evidence_refs",
      "trigger_logic",
      "confidence",
      "expected_window",
      "invalidation_conditions",
      "monitor_next"
    ]
  },
  "ownership": {
    "owner": "risk-team",
    "reviewer": "listing-risk",
    "created_at": "2026-03-26",
    "last_validated_at": "2026-04-12"
  }
}
