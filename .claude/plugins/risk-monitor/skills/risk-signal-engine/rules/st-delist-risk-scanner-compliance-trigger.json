{
  "rule_id": "ST_003",
  "version": "0.1.0",
  "status": "active",
  "rule_type": "event_only",
  "risk_dimensions": [
    "st-delist-risk-scanner"
  ],
  "scope": {
    "market": "CN-A",
    "universe": "all_watchlist",
    "position_stage": "post_position"
  },
  "inputs_required": [
    {
      "name": "exchange_inquiry_unresolved_days",
      "type": "number",
      "source": "announcement",
      "required": true
    },
    {
      "name": "major_violation_case",
      "type": "boolean",
      "source": "news",
      "required": true
    }
  ],
  "logic": {
    "expression": "exchange_inquiry_unresolved_days > 30 || major_violation_case == true",
    "thresholds": {
      "exchange_inquiry_unresolved_days": 30
    },
    "lookback_window": "90d",
    "trigger_mode": "event",
    "explain_template": "监管问询长期未回复或重大违规立案，退市与交易限制风险升温。"
  },
  "severity": {
    "mapping": [
      {
        "condition": "major_violation_case == true && exchange_inquiry_unresolved_days > 60",
        "level": "critical"
      }
    ],
    "default_level": "high"
  },
  "confidence": {
    "method": "heuristic",
    "base_score": 0.8
  },
  "event_triggers": [
    {
      "source": "announcement",
      "event_type": "exchange_inquiry",
      "action": "open_watch"
    },
    {
      "source": "news",
      "event_type": "regulatory_case_filing",
      "action": "escalate"
    }
  ],
  "invalidation_conditions": [
    "exchange_inquiry_unresolved_days < 10",
    "major_violation_case == false"
  ],
  "output_contract": {
    "must_include_fields": [
      "alert_id",
      "security_id",
      "as_of_date",
      "risk_type",
      "severity",
      "thesis",
      "evidence_refs",
      "trigger_logic",
      "confidence",
      "expected_window",
      "invalidation_conditions",
      "monitor_next"
    ]
  },
  "ownership": {
    "owner": "risk-team",
    "reviewer": "listing-risk",
    "created_at": "2026-03-26",
    "last_validated_at": "2026-04-12"
  },
  "legacy_parity_refs": [
    {
      "capability_id": "CAP-005",
      "risk_dimension": "st-delist-risk-scanner",
      "legacy_skill_path": ".claude/plugins/risk-monitor/skills/legacy/st-delist-risk-scanner",
      "legacy_capability_unit": "ST/退市触发条件扫描"
    }
  ]
}
