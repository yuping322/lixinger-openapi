{
  "rule_id": "SHH_RISK_003",
  "version": "0.1.0",
  "status": "active",
  "rule_type": "event_only",
  "risk_dimensions": [
    "shareholder-risk-check"
  ],
  "scope": {
    "market": "CN-A",
    "universe": "all_watchlist",
    "position_stage": "post_position"
  },
  "inputs_required": [
    {
      "name": "controlling_holder_equity_frozen_ratio",
      "type": "number",
      "source": "announcement",
      "required": true
    },
    {
      "name": "legal_dispute_count_12m",
      "type": "number",
      "source": "news",
      "required": true
    }
  ],
  "logic": {
    "expression": "controlling_holder_equity_frozen_ratio > 0.1 || legal_dispute_count_12m >= 3",
    "thresholds": {
      "controlling_holder_equity_frozen_ratio": 0.1,
      "legal_dispute_count_12m": 3
    },
    "lookback_window": "12m",
    "trigger_mode": "event",
    "explain_template": "\u63a7\u80a1\u80a1\u4e1c\u80a1\u4efd\u51bb\u7ed3\u6216\u8bc9\u8bbc\u9891\u53d1\uff0c\u6cbb\u7406\u4e0e\u8d44\u91d1\u94fe\u98ce\u9669\u4e0a\u5347\u3002"
  },
  "severity": {
    "mapping": [
      {
        "condition": "controlling_holder_equity_frozen_ratio > 0.2",
        "level": "critical"
      }
    ],
    "default_level": "high"
  },
  "confidence": {
    "method": "heuristic",
    "base_score": 0.82
  },
  "event_triggers": [
    {
      "source": "announcement",
      "event_type": "equity_freeze_notice",
      "action": "escalate"
    },
    {
      "source": "news",
      "event_type": "major_legal_dispute",
      "action": "recompute"
    }
  ],
  "invalidation_conditions": [
    "controlling_holder_equity_frozen_ratio == 0",
    "legal_dispute_count_12m <= 1"
  ],
  "output_contract": {
    "must_include_fields": [
      "alert_id",
      "security_id",
      "as_of_date",
      "risk_type",
      "severity",
      "thesis",
      "evidence_refs",
      "trigger_logic",
      "confidence",
      "expected_window",
      "invalidation_conditions",
      "monitor_next"
    ]
  },
  "ownership": {
    "owner": "risk-team",
    "reviewer": "governance-risk",
    "created_at": "2026-03-26",
    "last_validated_at": "2026-04-12"
  }
}
