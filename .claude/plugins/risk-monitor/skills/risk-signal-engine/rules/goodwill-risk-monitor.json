{
  "rule_id": "GOODWILL_001",
  "version": "0.1.0",
  "status": "active",
  "rule_type": "single_dimension",
  "risk_dimensions": [
    "goodwill-risk-monitor"
  ],
  "scope": {
    "market": "CN-A",
    "universe": "all_watchlist",
    "position_stage": "post_selection_pre_position"
  },
  "inputs_required": [
    {
      "name": "goodwill_to_equity",
      "type": "number",
      "source": "financial_statement",
      "required": true
    },
    {
      "name": "profit_growth_yoy",
      "type": "number",
      "source": "financial_statement",
      "required": true
    }
  ],
  "logic": {
    "expression": "goodwill_to_equity >= 0.35 && profit_growth_yoy <= 0",
    "thresholds": {
      "goodwill_to_equity": 0.35,
      "profit_growth_yoy": 0
    },
    "lookback_window": "4q",
    "trigger_mode": "batch",
    "explain_template": "商誉占净资产偏高且盈利承压，减值风险可能在财报窗口集中释放。"
  },
  "severity": {
    "mapping": [
      {
        "condition": "goodwill_to_equity >= 0.5",
        "level": "high"
      }
    ],
    "default_level": "medium"
  },
  "confidence": {
    "method": "heuristic",
    "base_score": 0.66
  },
  "event_triggers": [
    {
      "source": "filing_update",
      "event_type": "impairment_hint",
      "action": "recompute"
    }
  ],
  "invalidation_conditions": [
    "goodwill_to_equity < 0.25",
    "verified_cashflow_recovery"
  ],
  "output_contract": {
    "must_include_fields": [
      "alert_id",
      "security_id",
      "as_of_date",
      "risk_type",
      "severity",
      "thesis",
      "evidence_refs",
      "trigger_logic",
      "confidence",
      "expected_window",
      "invalidation_conditions",
      "monitor_next"
    ]
  },
  "ownership": {
    "owner": "risk-team",
    "reviewer": "financial-quality",
    "created_at": "2026-03-26",
    "last_validated_at": "2026-04-12"
  },
  "legacy_parity_refs": [
    {
      "capability_id": "CAP-004",
      "risk_dimension": "goodwill-risk-monitor",
      "legacy_skill_path": ".claude/plugins/risk-monitor/skills/legacy/goodwill-risk-monitor",
      "legacy_capability_unit": "商誉减值与并购后遗症风险监控"
    }
  ]
}
