{
  "rule_id": "LOCKUP_001",
  "version": "0.1.0",
  "status": "active",
  "rule_type": "single_dimension",
  "risk_dimensions": [
    "ipo-lockup-risk-monitor"
  ],
  "scope": {
    "market": "CN-A",
    "universe": "all_watchlist",
    "position_stage": "post_selection_pre_position"
  },
  "inputs_required": [
    {
      "name": "unlock_value_to_adv20",
      "type": "number",
      "source": "announcement+market",
      "required": true
    },
    {
      "name": "days_to_unlock",
      "type": "number",
      "source": "announcement",
      "required": true
    }
  ],
  "logic": {
    "expression": "days_to_unlock <= 30 && unlock_value_to_adv20 >= 5",
    "thresholds": {
      "days_to_unlock": 30,
      "unlock_value_to_adv20": 5
    },
    "lookback_window": "30d",
    "trigger_mode": "hybrid",
    "explain_template": "\u89e3\u7981\u89c4\u6a21\u76f8\u5bf9\u6210\u4ea4\u627f\u63a5\u8fc7\u5927\uff0c\u5b58\u5728\u96c6\u4e2d\u4f9b\u7ed9\u51b2\u51fb\u3002"
  },
  "severity": {
    "mapping": [
      {
        "condition": "unlock_value_to_adv20 >= 10",
        "level": "critical"
      }
    ],
    "default_level": "high"
  },
  "confidence": {
    "method": "heuristic",
    "base_score": 0.75
  },
  "event_triggers": [
    {
      "source": "announcement",
      "event_type": "unlock_schedule_change",
      "action": "recompute"
    }
  ],
  "invalidation_conditions": [
    "days_to_unlock > 60",
    "actual_reduction_ratio_low_after_unlock"
  ],
  "output_contract": {
    "must_include_fields": [
      "alert_id",
      "security_id",
      "as_of_date",
      "risk_type",
      "severity",
      "thesis",
      "evidence_refs",
      "trigger_logic",
      "confidence",
      "expected_window",
      "invalidation_conditions",
      "monitor_next"
    ]
  },
  "ownership": {
    "owner": "risk-team",
    "reviewer": "liquidity",
    "created_at": "2026-03-26",
    "last_validated_at": "2026-04-12"
  }
}
