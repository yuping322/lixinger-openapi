{
  "rule_id": "ST_001",
  "version": "0.1.0",
  "status": "active",
  "rule_type": "single_dimension",
  "risk_dimensions": [
    "st-delist-risk-scanner"
  ],
  "scope": {
    "market": "CN-A",
    "universe": "all_watchlist",
    "position_stage": "post_position"
  },
  "inputs_required": [
    {
      "name": "st_flag",
      "type": "boolean",
      "source": "exchange",
      "required": true
    }
  ],
  "logic": {
    "expression": "st_flag == true",
    "thresholds": {
      "st_flag": "true"
    },
    "lookback_window": "5d",
    "trigger_mode": "event",
    "explain_template": "\u89e6\u53d1ST\u76f8\u5173\u6807\u7b7e\uff0c\u4ea4\u6613\u9650\u5236\u4e0e\u4f30\u503c\u6298\u4ef7\u98ce\u9669\u663e\u8457\u62ac\u5347\u3002"
  },
  "severity": {
    "mapping": [
      {
        "condition": "true",
        "level": "critical"
      }
    ],
    "default_level": "critical"
  },
  "confidence": {
    "method": "fixed",
    "base_score": 0.9
  },
  "event_triggers": [
    {
      "source": "announcement",
      "event_type": "st_or_delist_notice",
      "action": "escalate"
    }
  ],
  "invalidation_conditions": [
    "st_flag_removed_by_exchange_notice"
  ],
  "output_contract": {
    "must_include_fields": [
      "alert_id",
      "security_id",
      "as_of_date",
      "risk_type",
      "severity",
      "thesis",
      "evidence_refs",
      "trigger_logic",
      "confidence",
      "expected_window",
      "invalidation_conditions",
      "monitor_next"
    ]
  },
  "ownership": {
    "owner": "risk-team",
    "reviewer": "compliance",
    "created_at": "2026-03-26",
    "last_validated_at": "2026-04-12"
  }
}
