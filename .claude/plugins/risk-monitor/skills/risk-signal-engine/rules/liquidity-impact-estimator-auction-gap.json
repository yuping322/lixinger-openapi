{
  "rule_id": "LIQ_003",
  "version": "0.1.0",
  "status": "active",
  "rule_type": "event_only",
  "risk_dimensions": [
    "liquidity-impact-estimator"
  ],
  "scope": {
    "market": "CN-A",
    "universe": "all_watchlist",
    "position_stage": "post_position"
  },
  "inputs_required": [
    {
      "name": "open_auction_gap",
      "type": "number",
      "source": "market",
      "required": true
    },
    {
      "name": "open_auction_turnover_ratio",
      "type": "number",
      "source": "market",
      "required": true
    }
  ],
  "logic": {
    "expression": "open_auction_gap < -0.04 && open_auction_turnover_ratio < 0.01",
    "thresholds": {
      "open_auction_gap": -0.04,
      "open_auction_turnover_ratio": 0.01
    },
    "lookback_window": "1d",
    "trigger_mode": "event",
    "explain_template": "\u4f4e\u627f\u63a5\u5f00\u76d8\u8df3\u7a7a\u4e0b\u8dcc\uff0c\u63d0\u793a\u6d41\u52a8\u6027\u771f\u7a7a\u98ce\u9669\u3002"
  },
  "severity": {
    "mapping": [
      {
        "condition": "open_auction_gap < -0.07",
        "level": "high"
      }
    ],
    "default_level": "medium"
  },
  "confidence": {
    "method": "heuristic",
    "base_score": 0.67
  },
  "event_triggers": [
    {
      "source": "market_anomaly",
      "event_type": "open_auction_dislocation",
      "action": "open_watch"
    }
  ],
  "invalidation_conditions": [
    "open_auction_gap > -0.01"
  ],
  "output_contract": {
    "must_include_fields": [
      "alert_id",
      "security_id",
      "as_of_date",
      "risk_type",
      "severity",
      "thesis",
      "evidence_refs",
      "trigger_logic",
      "confidence",
      "expected_window",
      "invalidation_conditions",
      "monitor_next"
    ]
  },
  "ownership": {
    "owner": "risk-team",
    "reviewer": "execution-risk",
    "created_at": "2026-03-26",
    "last_validated_at": "2026-04-12"
  }
}
