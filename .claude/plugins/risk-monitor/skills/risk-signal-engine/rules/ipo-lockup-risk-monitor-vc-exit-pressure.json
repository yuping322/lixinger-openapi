{
  "rule_id": "LOCKUP_003",
  "version": "0.1.0",
  "status": "active",
  "rule_type": "event_only",
  "risk_dimensions": [
    "ipo-lockup-risk-monitor"
  ],
  "scope": {
    "market": "CN-A",
    "universe": "recent_ipo",
    "position_stage": "post_position"
  },
  "inputs_required": [
    {
      "name": "pre_ipo_pe_unlocking",
      "type": "boolean",
      "source": "filing_update",
      "required": true
    },
    {
      "name": "block_trade_discount",
      "type": "number",
      "source": "market",
      "required": true
    }
  ],
  "logic": {
    "expression": "pre_ipo_pe_unlocking == true && block_trade_discount < -0.06",
    "thresholds": {
      "block_trade_discount": -0.06
    },
    "lookback_window": "30d",
    "trigger_mode": "event",
    "explain_template": "PE/VC\u89e3\u7981\u53e0\u52a0\u5927\u5b97\u6298\u4ef7\u6210\u4ea4\uff0c\u9000\u51fa\u538b\u529b\u53ef\u80fd\u5411\u4e8c\u7ea7\u5e02\u573a\u6269\u6563\u3002"
  },
  "severity": {
    "mapping": [
      {
        "condition": "block_trade_discount < -0.1",
        "level": "high"
      }
    ],
    "default_level": "medium"
  },
  "confidence": {
    "method": "heuristic",
    "base_score": 0.72
  },
  "event_triggers": [
    {
      "source": "market_anomaly",
      "event_type": "block_trade_discount_widen",
      "action": "escalate"
    },
    {
      "source": "filing_update",
      "event_type": "share_unlock_notice",
      "action": "open_watch"
    }
  ],
  "invalidation_conditions": [
    "pre_ipo_pe_unlocking == false",
    "block_trade_discount >= -0.02"
  ],
  "output_contract": {
    "must_include_fields": [
      "alert_id",
      "security_id",
      "as_of_date",
      "risk_type",
      "severity",
      "thesis",
      "evidence_refs",
      "trigger_logic",
      "confidence",
      "expected_window",
      "invalidation_conditions",
      "monitor_next"
    ]
  },
  "ownership": {
    "owner": "risk-team",
    "reviewer": "event-risk",
    "created_at": "2026-03-26",
    "last_validated_at": "2026-04-12"
  }
}
