{
  "rule_id": "LOCKUP_003",
  "version": "0.1.0",
  "status": "active",
  "rule_type": "event_only",
  "risk_dimensions": [
    "ipo-lockup-risk-monitor"
  ],
  "scope": {
    "market": "CN-A",
    "universe": "recent_ipo",
    "position_stage": "post_position"
  },
  "inputs_required": [
    {
      "name": "pre_ipo_pe_unlocking",
      "type": "boolean",
      "source": "filing_update",
      "required": true
    },
    {
      "name": "block_trade_discount",
      "type": "number",
      "source": "market",
      "required": true
    }
  ],
  "logic": {
    "expression": "pre_ipo_pe_unlocking == true && block_trade_discount < -0.06",
    "thresholds": {
      "block_trade_discount": -0.06
    },
    "lookback_window": "30d",
    "trigger_mode": "event",
    "explain_template": "PE/VC解禁叠加大宗折价成交，退出压力可能向二级市场扩散。"
  },
  "severity": {
    "mapping": [
      {
        "condition": "block_trade_discount < -0.1",
        "level": "high"
      }
    ],
    "default_level": "medium"
  },
  "confidence": {
    "method": "heuristic",
    "base_score": 0.72
  },
  "event_triggers": [
    {
      "source": "market_anomaly",
      "event_type": "block_trade_discount_widen",
      "action": "escalate"
    },
    {
      "source": "filing_update",
      "event_type": "share_unlock_notice",
      "action": "open_watch"
    }
  ],
  "invalidation_conditions": [
    "pre_ipo_pe_unlocking == false",
    "block_trade_discount >= -0.02"
  ],
  "output_contract": {
    "must_include_fields": [
      "alert_id",
      "security_id",
      "as_of_date",
      "risk_type",
      "severity",
      "thesis",
      "evidence_refs",
      "trigger_logic",
      "confidence",
      "expected_window",
      "invalidation_conditions",
      "monitor_next"
    ]
  },
  "ownership": {
    "owner": "risk-team",
    "reviewer": "event-risk",
    "created_at": "2026-03-26"
  }
}
