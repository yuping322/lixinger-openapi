{
  "rule_id": "CROSS_001",
  "version": "0.1.0",
  "status": "active",
  "rule_type": "cross_dimension",
  "risk_dimensions": [
    "ipo-lockup-risk-monitor",
    "equity-pledge-risk-monitor",
    "liquidity-impact-estimator"
  ],
  "scope": {
    "market": "CN-A",
    "universe": "all_watchlist",
    "position_stage": "post_position"
  },
  "inputs_required": [
    {
      "name": "unlock_value_to_adv20",
      "type": "number",
      "source": "announcement+market",
      "required": true
    },
    {
      "name": "pledge_ratio_controller",
      "type": "number",
      "source": "announcement",
      "required": true
    },
    {
      "name": "size_to_adv",
      "type": "number",
      "source": "portfolio+market",
      "required": true
    }
  ],
  "logic": {
    "expression": "unlock_value_to_adv20 >= 5 && pledge_ratio_controller >= 0.7 && size_to_adv >= 0.2",
    "thresholds": {
      "unlock_value_to_adv20": 5,
      "pledge_ratio_controller": 0.7,
      "size_to_adv": 0.2
    },
    "lookback_window": "30d",
    "trigger_mode": "event",
    "explain_template": "\u4f9b\u7ed9\u51b2\u51fb\u3001\u80a1\u4e1c\u8106\u5f31\u4e0e\u6267\u884c\u6d41\u52a8\u6027\u540c\u65f6\u6076\u5316\uff0c\u5f62\u6210\u590d\u5408\u8e29\u8e0f\u98ce\u9669\u3002"
  },
  "severity": {
    "mapping": [
      {
        "condition": "unlock_value_to_adv20 >= 8",
        "level": "critical"
      }
    ],
    "default_level": "high"
  },
  "confidence": {
    "method": "heuristic",
    "base_score": 0.78
  },
  "event_triggers": [
    {
      "source": "announcement",
      "event_type": "unlock_schedule_change",
      "action": "recompute"
    },
    {
      "source": "news",
      "event_type": "controller_pledge_risk_news",
      "action": "escalate"
    }
  ],
  "invalidation_conditions": [
    "unlock_value_to_adv20 < 2",
    "pledge_ratio_controller < 0.5",
    "size_to_adv < 0.1"
  ],
  "output_contract": {
    "must_include_fields": [
      "alert_id",
      "security_id",
      "as_of_date",
      "risk_type",
      "severity",
      "thesis",
      "evidence_refs",
      "trigger_logic",
      "confidence",
      "expected_window",
      "invalidation_conditions",
      "monitor_next"
    ]
  },
  "ownership": {
    "owner": "risk-team",
    "reviewer": "cross-risk",
    "created_at": "2026-03-26",
    "last_validated_at": "2026-04-12"
  }
}
