{
  "rule_id": "SHH_STRUCT_003",
  "version": "0.1.0",
  "status": "active",
  "rule_type": "event_only",
  "risk_dimensions": [
    "shareholder-structure-monitor"
  ],
  "scope": {
    "market": "CN-A",
    "universe": "all_watchlist",
    "position_stage": "post_position"
  },
  "inputs_required": [
    {
      "name": "related_party_holding_increase",
      "type": "number",
      "source": "filing_update",
      "required": true
    },
    {
      "name": "independent_director_resign",
      "type": "boolean",
      "source": "announcement",
      "required": true
    }
  ],
  "logic": {
    "expression": "related_party_holding_increase > 0.05 && independent_director_resign == true",
    "thresholds": {
      "related_party_holding_increase": 0.05
    },
    "lookback_window": "2q",
    "trigger_mode": "event",
    "explain_template": "\u5173\u8054\u65b9\u6301\u80a1\u4e0a\u5347\u4e14\u72ec\u7acb\u8463\u4e8b\u79bb\u4efb\uff0c\u6cbb\u7406\u5236\u8861\u53ef\u80fd\u5f31\u5316\u3002"
  },
  "severity": {
    "mapping": [
      {
        "condition": "related_party_holding_increase > 0.1",
        "level": "high"
      }
    ],
    "default_level": "medium"
  },
  "confidence": {
    "method": "heuristic",
    "base_score": 0.69
  },
  "event_triggers": [
    {
      "source": "announcement",
      "event_type": "independent_director_resign",
      "action": "open_watch"
    },
    {
      "source": "filing_update",
      "event_type": "related_party_transaction_update",
      "action": "recompute"
    }
  ],
  "invalidation_conditions": [
    "related_party_holding_increase < 0.02",
    "independent_director_resign == false"
  ],
  "output_contract": {
    "must_include_fields": [
      "alert_id",
      "security_id",
      "as_of_date",
      "risk_type",
      "severity",
      "thesis",
      "evidence_refs",
      "trigger_logic",
      "confidence",
      "expected_window",
      "invalidation_conditions",
      "monitor_next"
    ]
  },
  "ownership": {
    "owner": "risk-team",
    "reviewer": "governance-risk",
    "created_at": "2026-03-26",
    "last_validated_at": "2026-04-12"
  }
}
