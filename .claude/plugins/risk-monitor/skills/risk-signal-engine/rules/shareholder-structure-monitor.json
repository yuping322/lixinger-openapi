  ],
  "logic": {
    "expression": "controller_stability_gap <= 0.05",
    "thresholds": {
      "controller_stability_gap": 0.05
    },
    "lookback_window": "4q",
    "trigger_mode": "batch",
    "explain_template": "\u63a7\u5236\u6743\u7a33\u5b9a\u6027\u4e0d\u8db3\uff0c\u5173\u952e\u80a1\u4e1c\u53d8\u52a8\u53ef\u80fd\u89e6\u53d1\u6cbb\u7406\u4e0d\u786e\u5b9a\u6027\u3002"
  },
  "severity": {
