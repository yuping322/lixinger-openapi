{
  "rule_id": "PORT_001",
  "version": "0.1.0",
  "status": "active",
  "rule_type": "portfolio_overlay",
  "risk_dimensions": [
    "margin-risk-monitor",
    "liquidity-impact-estimator",
    "limit-up-limit-down-risk-checker"
  ],
  "scope": {
    "market": "CN-A",
    "universe": "all_watchlist",
    "position_stage": "post_position"
  },
  "inputs_required": [
    {
      "name": "portfolio_exposure_to_high_margin_names",
      "type": "number",
      "source": "manual",
      "required": true
    },
    {
      "name": "portfolio_liquidity_days_to_exit",
      "type": "number",
      "source": "manual",
      "required": true
    },
    {
      "name": "portfolio_limit_down_name_ratio",
      "type": "number",
      "source": "manual",
      "required": true
    }
  ],
  "logic": {
    "expression": "portfolio_exposure_to_high_margin_names > 0.35 && portfolio_liquidity_days_to_exit > 5 && portfolio_limit_down_name_ratio > 0.1",
    "thresholds": {
      "portfolio_exposure_to_high_margin_names": 0.35,
      "portfolio_liquidity_days_to_exit": 5,
      "portfolio_limit_down_name_ratio": 0.1
    },
    "lookback_window": "1d",
    "trigger_mode": "hybrid",
    "explain_template": "组合拥挤杠杆敞口与流动性退出周期错配，需主动降风险。"
  },
  "severity": {
    "mapping": [
      {
        "condition": "portfolio_liquidity_days_to_exit > 8",
        "level": "critical"
      }
    ],
    "default_level": "high"
  },
  "confidence": {
    "method": "heuristic",
    "base_score": 0.73
  },
  "event_triggers": [
    {
      "source": "manual",
      "event_type": "portfolio_rebalance_review",
      "action": "recompute"
    },
    {
      "source": "market_anomaly",
      "event_type": "broad_limit_down_wave",
      "action": "escalate"
    }
  ],
  "invalidation_conditions": [
    "portfolio_exposure_to_high_margin_names < 0.2",
    "portfolio_liquidity_days_to_exit <= 3"
  ],
  "output_contract": {
    "must_include_fields": [
      "alert_id",
      "security_id",
      "as_of_date",
      "risk_type",
      "severity",
      "thesis",
      "evidence_refs",
      "trigger_logic",
      "confidence",
      "expected_window",
      "invalidation_conditions",
      "monitor_next"
    ]
  },
  "ownership": {
    "owner": "risk-team",
    "reviewer": "portfolio-risk",
    "created_at": "2026-03-26",
    "last_validated_at": "2026-04-12"
  },
  "legacy_parity_refs": [
    {
      "capability_id": "CAP-007",
      "risk_dimension": "margin-risk-monitor",
      "legacy_skill_path": ".claude/plugins/risk-monitor/skills/legacy/margin-risk-monitor",
      "legacy_capability_unit": "两融杠杆拥挤与踩踏风险监控"
    },
    {
      "capability_id": "CAP-009",
      "risk_dimension": "liquidity-impact-estimator",
      "legacy_skill_path": ".claude/plugins/risk-monitor/skills/legacy/liquidity-impact-estimator",
      "legacy_capability_unit": "交易冲击成本与流动性缺口评估"
    },
    {
      "capability_id": "CAP-008",
      "risk_dimension": "limit-up-limit-down-risk-checker",
      "legacy_skill_path": ".claude/plugins/risk-monitor/skills/legacy/limit-up-limit-down-risk-checker",
      "legacy_capability_unit": "涨跌停板流动性锁死风险检查"
    }
  ]
}
