{
  "rule_id": "LIQ_002",
  "version": "0.1.0",
  "status": "active",
  "rule_type": "single_dimension",
  "risk_dimensions": [
    "liquidity-impact-estimator"
  ],
  "scope": {
    "market": "CN-A",
    "universe": "all_watchlist",
    "position_stage": "post_selection_pre_position"
  },
  "inputs_required": [
    {
      "name": "estimated_slippage_1pct_notional",
      "type": "number",
      "source": "market",
      "required": true
    },
    {
      "name": "top5_depth_amount",
      "type": "number",
      "source": "market",
      "required": true
    }
  ],
  "logic": {
    "expression": "estimated_slippage_1pct_notional > 0.015 && top5_depth_amount < 5000000",
    "thresholds": {
      "estimated_slippage_1pct_notional": 0.015,
      "top5_depth_amount": 5000000
    },
    "lookback_window": "20d",
    "trigger_mode": "batch",
    "explain_template": "冲击成本抬升且盘口深度不足，大额交易执行风险显著。"
  },
  "severity": {
    "mapping": [
      {
        "condition": "estimated_slippage_1pct_notional > 0.025",
        "level": "high"
      }
    ],
    "default_level": "medium"
  },
  "confidence": {
    "method": "heuristic",
    "base_score": 0.76
  },
  "event_triggers": [
    {
      "source": "market_anomaly",
      "event_type": "order_book_thinning",
      "action": "recompute"
    }
  ],
  "invalidation_conditions": [
    "estimated_slippage_1pct_notional < 0.01",
    "top5_depth_amount >= 8000000"
  ],
  "output_contract": {
    "must_include_fields": [
      "alert_id",
      "security_id",
      "as_of_date",
      "risk_type",
      "severity",
      "thesis",
      "evidence_refs",
      "trigger_logic",
      "confidence",
      "expected_window",
      "invalidation_conditions",
      "monitor_next"
    ]
  },
  "ownership": {
    "owner": "risk-team",
    "reviewer": "execution-risk",
    "created_at": "2026-03-26"
  }
}
