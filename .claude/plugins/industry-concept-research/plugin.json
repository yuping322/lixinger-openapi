  "contracts": {
    "research_conclusion": "contracts/research-conclusion.schema.json",
    "monitoring_checklist": "contracts/monitoring-checklist.schema.json",
    "data_gap_report": "contracts/data-gap-report.schema.json",
    "inter_plugin_interface": "contracts/inter-plugin-interface.schema.json",
    "qc_rules": "contracts/qc-rules.schema.json"
  },
  "reuse_patterns": [
    {
      "pattern_id": "P1",
      "pattern_name": "SINGLE_INDUSTRY_ANALYSIS",
      "description": "对单一申万行业做完整的估值+轮动+产业链+政策全维度分析",
      "entry_command": "industry-concept-research",
      "entry_skills": [
        "industry-board-analyzer",
        "sector-rotation-detector",
        "industry-chain-mapper",
        "policy-sensitivity-brief"
      ],
      "typical_use_case": "分析'电子行业'当前投资价值"
    },
    {
      "pattern_id": "P2",
      "pattern_name": "INDUSTRY_COMPARISON",
      "description": "跨多个行业的横截面对比分析，识别相对强弱",
      "entry_command": "industry-board-analyzer",
      "entry_skills": [
        "industry-board-analyzer",
        "sector-rotation-detector"
      ],
      "typical_use_case": "对比消费/科技/金融三个行业的配置价值"
    },
    {
      "pattern_id": "P3",
      "pattern_name": "SECTOR_ROTATION_TRACKING",
      "description": "持续跟踪行业轮动动态，识别资金流入/流出信号",
      "entry_command": "sector-rotation-detector",
      "entry_skills": [
        "sector-rotation-detector",
        "limit-up-down-linkage-detector",
        "board-crowding-risk-monitor"
      ],
      "typical_use_case": "每周更新行业配置建议，跟踪轮动方向"
    },
    {
      "pattern_id": "P4",
      "pattern_name": "CONCEPT_THEME_TRACKING",
      "description": "跟踪主题概念板块的生命周期状态和拥挤度风险",
      "entry_command": "concept-board-analyzer",
      "entry_skills": [
        "concept-board-analyzer",
        "board-crowding-risk-monitor",
        "limit-up-down-linkage-detector"
      ],
      "typical_use_case": "跟踪'AI算力'概念板块是否处于拥挤阶段"
    },
    {
      "pattern_id": "P5",
      "pattern_name": "POLICY_RESPONSE_ANALYSIS",
      "description": "政策事件发生后，快速评估受益/受损行业和传导路径",
      "entry_command": "policy-sensitivity-brief",
      "entry_skills": [
        "policy-sensitivity-brief",
        "industry-chain-mapper",
        "industry-board-analyzer"
      ],
      "typical_use_case": "国务院出台新能源补贴政策后，评估各相关行业的政策敏感度"
    }
  ],
  "external_consumers": [
    {
      "consumer_plugin": "valuation",
      "consumed_skills": [
        "industry-board-analyzer",
        "industry-chain-mapper"
      ],
      "consumption_pattern": "在估值分析中获取目标公司所属行业的估值分位数和产业链地位，作为相对估值参考基准"
    },
    {
      "consumer_plugin": "regime-lab",
      "consumed_skills": [
        "sector-rotation-detector"
      ],
      "consumption_pattern": "将行业轮动信号作为 regime 状态的行业层面验证，增强 regime 判断的置信度"
    },
    {
      "consumer_plugin": "deep-research",
      "consumed_skills": [
        "industry-board-analyzer",
        "industry-chain-mapper",
        "policy-sensitivity-brief"
      ],
      "consumption_pattern": "在深度研报中获取行业背景、产业链分析和政策敏感度作为研究证据链的一部分"
    }
  ],
  "dependencies": {
    "data_sources": [
      {
        "id": "lixinger-openapi",
        "description": "理杏仁 OpenAPI（行业基本面、估值、财务数据）",
        "query_tool": "python3 .claude/plugins/query_data/lixinger-api-docs/scripts/query_tool.py",
        "required": true
      },
      {
        "id": "akshare",
        "description": "AKShare（概念板块资金流向、换手率等高频数据）",
        "required": false,
        "fallback": "降级为仅使用理杏仁估值数据，置信度下调"
      }
    ],
    "plugins": [
      {
        "id": "query_data",
        "usage": "数据查询底座，提供 query_tool.py 统一接口",
        "required": true
      }
    ]
  },
  "quality_gates": {
    "output_decision_thresholds": {
      "CONCLUSION": {
        "confidence_min": 0.6,
        "required_skills_min": 3
      },
      "WARNING": {
        "confidence_range": [
          0.3,
          0.6
        ]
      },
      "REFUSE": {
        "confidence_max": 0.3
      }
    },
    "qc_rules_ref": "contracts/qc-rules.schema.json"
  },
  "fail_safe": {
    "strategy": "GRACEFUL_DEGRADE",
    "description": "任一模块缺数时，优先使用降级方案继续分析并在输出中标注缺口；仅当置信度低于30%或核心模块全部失败时触发 REFUSE。",
    "never_silent_degrade": true,
    "data_gap_disclosure_field": "data_gaps"
  }
}
