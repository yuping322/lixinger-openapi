{
  "id": "industry-concept-research",
  "name": "行业与概念研究一体化分析插件",
  "version": "2.1.0",
  "description": "面向 A 股行业板块与概念板块研究的一体化分析插件。整合行业估值、轮动探测、产业链映射、概念分析、政策敏感度、涨跌停联动、研报分析、行业细分拆解、因子归因、板块拥挤度监控十大分析模块，支持快速模式（T+0 复盘）和完整模式（深度研究），输出带置信度、失效条件和嵌套 monitoring_checklist（checklist + indicators[]）的结构化研究结论。",
  "author": "lixinger-openapi",
  "license": "MIT",
  "created_at": "2025-01-01",
  "updated_at": "2026-04-10",
  "status": "production",
  "target_market": "A股",
  "capabilities": [
    "行业板块横截面估值分析（申万2021一级行业，31个）",
    "宏观经济周期驱动的行业轮动信号（超配/标配/低配）",
    "申万一级→二级→三级行业细分拆解与强弱分层",
    "产业链上下游传导分析（价格/业绩/供需三层传导）",
    "概念主题生命周期识别（启动/扩散/拥挤/退潮四阶段）",
    "政策敏感度评估与情景推演（超预期/符合/低于预期）",
    "涨跌停联动与板块扩散追踪",
    "板块因子归因（估值扩张/EPS上修/风险溢价三维）",
    "板块拥挤度监控与脆弱触发器识别",
    "卖方研报综合分析与多空分歧评估"
  ],
  "commands": [
    {
      "id": "industry-concept-research",
      "path": "commands/industry-concept-research.md",
      "description": "统一 Orchestrator 入口：自动编排所有分析模块，支持 quick/full/detailed 三种模式，输出带 QA 自检的结构化研究结论",
      "is_primary": true
    },
    {
      "id": "industry-board-analyzer",
      "path": "commands/industry-board-analyzer.md",
      "description": "行业板块横截面分析：估值分位数、动量、股息率、综合评分"
    },
    {
      "id": "sector-rotation-detector",
      "path": "commands/sector-rotation-detector.md",
      "description": "宏观驱动的行业轮动信号探测：五大宏观支柱 + 经济周期定位"
    },
    {
      "id": "industry-chain-mapper",
      "path": "commands/industry-chain-mapper.md",
      "description": "产业链上下游传导分析：价格/业绩/供需三层传导框架"
    },
    {
      "id": "concept-board-analyzer",
      "path": "commands/concept-board-analyzer.md",
      "description": "概念板块主题生命周期分析：启动/扩散/拥挤/退潮四阶段判断"
    },
    {
      "id": "policy-sensitivity-brief",
      "path": "commands/policy-sensitivity-brief.md",
      "description": "政策敏感度简报：政策链条传导分析 + 情景推演"
    },
    {
      "id": "limit-up-down-linkage-detector",
      "path": "commands/limit-up-down-linkage-detector.md",
      "description": "涨跌停联动探测：板块扩散追踪 + 主力意图识别"
    },
    {
      "id": "industry-report-analyzer",
      "path": "commands/industry-report-analyzer.md",
      "description": "行业研报综合分析：卖方观点聚合 + 多空分歧评估"
    },
    {
      "id": "industry-subsector-decomposer",
      "path": "commands/industry-subsector-decomposer.md",
      "description": "行业细分拆解：申万一级→二级→三级下钻，识别细分强弱和 Alpha 来源"
    },
    {
      "id": "sector-factor-attributor",
      "path": "commands/sector-factor-attributor.md",
      "description": "板块因子归因：估值扩张/EPS预期上修/风险溢价三维归因 + 风格因子暴露"
    },
    {
      "id": "board-crowding-risk-monitor",
      "path": "commands/board-crowding-risk-monitor.md",
      "description": "板块拥挤度监控：拥挤度评分 + 脆弱触发器识别 + 降仓/观察建议"
    }
  ],
