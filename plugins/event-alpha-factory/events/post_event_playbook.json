{
  "version": "1.0.0",
  "playbooks": [
    {
      "event_type": "earnings_beat",
      "validation_windows": ["1D", "5D", "20D"],
      "checklist": {
        "1D": ["首日跳空后是否回补超50%", "成交额是否高于近20日均值1.5x"],
        "5D": ["分析师一致预期是否上修", "同业是否出现跟随正向反应"],
        "20D": ["估值中枢是否上移", "盈利预期上修是否被价格确认"]
      },
      "watch_items": ["管理层指引", "产业链高频数据", "卖方覆盖变化"],
      "failure_patterns": ["放量长上影", "指引保守导致二次下修"]
    },
    {
      "event_type": "share_repurchase",
      "validation_windows": ["1D", "5D", "20D"],
      "checklist": {
        "1D": ["公告后是否出现净流入", "价格是否站上事件日前20日均线"],
        "5D": ["是否披露回购实施进度", "回购价格区间是否具备支撑意义"],
        "20D": ["回购执行比例是否达预期", "估值折价是否修复"]
      },
      "watch_items": ["回购实施公告", "公司现金流", "管理层增减持"],
      "failure_patterns": ["只公告不实施", "回购规模低于预期"]
    },
    {
      "event_type": "lockup_expiry_risk",
      "validation_windows": ["1D", "5D", "20D"],
      "checklist": {
        "1D": ["解禁当日换手率是否异常放大", "是否出现明显折价大宗"],
        "5D": ["主力资金是否持续流出", "短期反弹是否乏量"],
        "20D": ["解禁压力是否被基本面兑现对冲", "估值是否重新定价"]
      },
      "watch_items": ["股东减持计划", "机构持仓变化", "行业景气度"],
      "failure_patterns": ["减持预期过强", "流动性承接不足"]
    }
  ]
}
