{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://lixinger-openapi.local/contracts/qc-rules.schema.json",
  "title": "QC Rules Schema",
  "description": "仅定义质量门控（QC）规则对象结构，不承载运行时阈值版本。",
  "type": "object",
  "required": [
    "version",
    "rules"
  ],
  "properties": {
    "version": {
      "type": "string",
      "description": "运行配置版本号（语义化版本）。",
      "pattern": "^v\\d+\\.\\d+\\.\\d+$"
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "effective_from": {
          "type": "string",
          "format": "date"
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "rules": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/rule"
      }
    }
  },
  "$defs": {
    "rule": {
      "type": "object",
      "required": [
        "id",
        "name",
        "enabled",
        "weight",
        "threshold",
        "trigger"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "enabled": {
          "type": "boolean"
        },
        "weight": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "threshold": {
          "$ref": "#/$defs/threshold"
        },
        "trigger": {
          "$ref": "#/$defs/trigger"
        }
      },
      "additionalProperties": false
    },
    "threshold": {
      "type": "object",
      "required": [
        "metric",
        "operator",
        "value"
      ],
      "properties": {
        "metric": {
          "type": "string"
        },
        "operator": {
          "type": "string",
          "enum": [
            ">",
            ">=",
            "<",
            "<=",
            "==",
            "between"
          ]
        },
        "value": {
          "oneOf": [
            {
              "type": "number"
            },
            {
              "type": "array",
              "items": {
                "type": "number"
              },
              "minItems": 2,
              "maxItems": 2
            }
          ]
        }
      },
      "additionalProperties": false
    },
    "trigger": {
      "type": "object",
      "required": [
        "when",
        "window"
      ],
      "properties": {
        "when": {
          "type": "string"
        },
        "window": {
          "type": "string",
          "description": "触发窗口，例如 close、intraday、t+1-open。"
        },
        "cooldown_days": {
          "type": "integer",
          "minimum": 0
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
